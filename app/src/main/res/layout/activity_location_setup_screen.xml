<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_obsidian">

    <View
        android:layout_width="300dp"
        android:layout_height="300dp"
        android:background="@drawable/bg_glow_emerald"
        android:alpha="0.15"
        android:translationX="-100dp"
        android:translationY="200dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>

    <LinearLayout
        android:id="@+id/contentContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="32dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:src="@drawable/assistant"
            android:layout_gravity="center"
            android:layout_marginBottom="24dp"
            app:tint="@color/terminal_green"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="DELIVERY TARGET"
            android:textSize="28sp"
            android:letterSpacing="0.1"
            android:fontFamily="sans-serif-black"
            android:textAlignment="center"
            android:textColor="@color/text_primary"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="To help delivery personnel navigate to your location precisely, EchoMi needs your exact coordinates."
            android:textSize="12sp"
            android:fontFamily="monospace"
            android:letterSpacing="0.05"
            android:textAlignment="center"
            android:layout_marginTop="16dp"
            android:textColor="@color/text_secondary"
            android:layout_marginBottom="48dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnDetectLocation"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="DETECT MY COORDINATES"
            android:textSize="14sp"
            android:textColor="@color/background_obsidian"
            android:textStyle="bold"
            android:fontFamily="monospace"
            android:letterSpacing="0.05"
            android:background="@drawable/bg_button_emerald"
            app:backgroundTint="@null" />

    </LinearLayout>

    <com.airbnb.lottie.LottieAnimationView
        android:id="@+id/loadingAnimationView"
        android:layout_width="150dp"
        android:layout_height="150dp"
        android:visibility="gone"
        app:lottie_rawRes="@raw/cool"
        app:lottie_autoPlay="true"
        app:lottie_loop="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>